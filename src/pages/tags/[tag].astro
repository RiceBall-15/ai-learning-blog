---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = new Set<string>();
  posts.forEach(post => {
    post.data.tags.forEach(tag => tags.add(tag));
  });

  return [...tags].map(tag => ({
    params: { tag },
    props: { tag, posts },
  }));
}

const { tag, posts } = Astro.props;
const tagPosts = posts.filter(post =>
  post.data.tags.includes(tag)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={`标签: ${tag} - LangChain4j 学习笔记`}>
  <div class="post-content">
    <h1>🏷️ 标签: #{tag}</h1>
    <p>找到 {tagPosts.length} 篇相关文章</p>

    <hr style="margin: 2rem 0; border: none; border-top: 1px solid var(--border);" />

    {tagPosts.length === 0 ? (
      <p>暂无相关文章</p>
    ) : (
      <div>
        {tagPosts.map((post) => (
          <article class="article-card">
            <h2 class="article-title">
              <a href={`/langchain4j-blog/${post.slug}`}>
                {post.data.title}
              </a>
            </h2>

            <div class="article-meta">
              <span>📅 {post.data.date.toLocaleDateString('zh-CN')}</span>
              {post.data.category && <span>📁 {post.data.category}</span>}
            </div>

            {post.data.description && (
              <p class="article-excerpt">{post.data.description}</p>
            )}

            {post.data.tags && post.data.tags.length > 0 && (
              <div class="tags">
                {post.data.tags.map(t => (
                  <a href={`/langchain4j-blog/tags/${t}`} class="tag">#{t}</a>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    )}
  </div>
</Layout>