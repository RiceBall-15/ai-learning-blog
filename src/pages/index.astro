---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 获取所有集合的文章
const langchain4jPosts = (await getCollection('langchain4j'))
  .filter(post => !post.data.draft);
const sglangPosts = (await getCollection('sglang'))
  .filter(post => !post.data.draft);
const llmTrainingPosts = (await getCollection('llmTraining'))
  .filter(post => !post.data.draft);

// 合并所有文章
const allPosts = [...langchain4jPosts, ...sglangPosts, ...llmTrainingPosts]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 按集合分组
const collections = {
  langchain4j: { name: 'LangChain4j', posts: langchain4jPosts },
  sglang: { name: 'SGLang', posts: sglangPosts },
  llmTraining: { name: 'LLM训练', posts: llmTrainingPosts },
};

// 获取所有标签
const allTags = new Set<string>();
allPosts.forEach(post => {
  post.data.tags.forEach(tag => allTags.add(tag));
});

const totalPosts = allPosts.length;
---

<Layout title="首页 - AI 学习笔记">
  <div style="display: grid; grid-template-columns: 3fr 1fr; gap: 2rem;">
    <div>
      <h1 style="font-size: 2.5rem; margin-bottom: 1rem; color: var(--text-primary);">
        🤖 AI 学习笔记
      </h1>
      <p style="color: var(--text-secondary); margin-bottom: 2rem; font-size: 1.1rem;">
        深入探索 LangChain4j、SGLang、LLM训练等AI技术
      </p>

      {totalPosts === 0 ? (
        <p style="color: var(--text-secondary);">暂无文章</p>
      ) : (
        <div>
          {/* 按分类显示文章 */}
          {Object.entries(collections).map(([key, { name, posts }]) => (
            posts.length > 0 && (
              <div key={key} style="margin-bottom: 3rem;">
                <h2 style="font-size: 1.8rem; margin-bottom: 1.5rem; color: var(--accent);">
                  {name}
                </h2>

                {posts.map((post) => (
                  <article class="article-card">
                    <h3 class="article-title">
                      <a href={`/${post.collection}/${post.slug}`}>
                        {post.data.title}
                      </a>
                    </h3>

                    <div class="article-meta">
                      <span>📅 {post.data.date.toLocaleDateString('zh-CN')}</span>
                      {post.data.category && <span>📁 {post.data.category}</span>}
                    </div>

                    {post.data.description && (
                      <p class="article-excerpt">{post.data.description}</p>
                    )}

                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="tags">
                        {post.data.tags.map(tag => (
                          <a href={`/tags/${tag}`} class="tag">#{tag}</a>
                        ))}
                      </div>
                    )}
                  </article>
                ))}
              </div>
            )
          ))}
        </div>
      )}
    </div>

    <aside>
      <div class="sidebar">
        <h3>📚 学习系列</h3>
        <ul>
          <li><a href="/">全部</a></li>
          <li><a href="/langchain4j/">LangChain4j</a></li>
          <li><a href="/sglang/">SGLang</a></li>
          <li><a href="/llm-training/">LLM训练</a></li>
        </ul>
      </div>

      <div class="sidebar">
        <h3>🏷️ 标签</h3>
        <div class="tags">
          {[...allTags].map(tag => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      </div>

      <div class="sidebar">
        <h3>📊 统计</h3>
        <ul>
          <li>文章总数: {totalPosts}</li>
          <li>标签数量: {allTags.size}</li>
          <li>系列数量: 3</li>
        </ul>
      </div>
    </aside>
  </div>
</Layout>